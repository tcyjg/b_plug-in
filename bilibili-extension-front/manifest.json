{
  "manifest_version": 3,
  "name": "Bilibili Video Summary",
  "version": "1.1",
  "description": "Generate AI video summaries on Bilibili pages.",
  "permissions": ["cookies", "activeTab", "storage"],
  "host_permissions": [
    "https://*.bilibili.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_title": "Open settings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://www.bilibili.com/video/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"]
    }
  ]
}
